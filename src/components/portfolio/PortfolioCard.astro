---
import { getPortfolioExternalHref, getPortfolioPoster, type PortfolioItem } from "@content/portfolio";
import VideoTile from "@components/ui/VideoTile.astro";

interface Props {
  item: PortfolioItem;
}

const { item } = Astro.props;
---

<VideoTile
  href={getPortfolioExternalHref(item)}
  thumbnail={getPortfolioPoster(item)}
  title={item.title}
  summary={item.description}
  eyebrow={item.industryTag ?? item.useCase}
  duration={item.duration}
  badge={item.platformTag}
  status={item.status}
/>
