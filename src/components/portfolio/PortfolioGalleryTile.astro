---
import { getPortfolioPoster, getPortfolioStatusText, type PortfolioItem } from "@content/portfolio";

interface Props {
  item: PortfolioItem;
  size?: "feature" | "standard" | "compact";
}

const { item, size = "standard" } = Astro.props;
const statusLabel = item.status !== "ready" ? getPortfolioStatusText(item) : undefined;
---

<article class:list={["portfolio-gallery-tile", "card", size === "feature" && "is-feature", size === "compact" && "is-compact"]}>
  <button class="tile-trigger" type="button" data-portfolio-open={item.id} aria-haspopup="dialog">
    <div class="tile-media">
      <img src={getPortfolioPoster(item)} alt={item.title} loading="lazy" decoding="async" />
      <span class="tile-duration">{item.duration ?? "Preview"}</span>
      {item.status === "ready" && item.featured ? <span class="tile-flag">Featured</span> : null}
      {statusLabel ? <span class="tile-status">{statusLabel}</span> : null}
    </div>
    <div class="tile-copy">
      <div class="tile-tags">
        <span class="tile-tag tile-tag-primary">{item.useCase}</span>
        {item.platformTag ? <span class="tile-tag">{item.platformTag}</span> : null}
      </div>
      <div class="tile-headline">
        <h3>{item.title}</h3>
        {item.industryTag ? <p class="tile-industry">{item.industryTag}</p> : null}
      </div>
      <p>{item.description}</p>
    </div>
  </button>
</article>

<style>
  .portfolio-gallery-tile {
    overflow: hidden;
    min-height: 100%;
  }

  .tile-trigger {
    width: 100%;
    height: 100%;
    padding: 0;
    border: 0;
    background: transparent;
    text-align: left;
    color: inherit;
    cursor: pointer;
    display: grid;
  }

  .tile-media {
    position: relative;
    aspect-ratio: 10 / 12;
    overflow: hidden;
    background: rgba(32, 24, 18, 0.08);
  }

  .tile-media::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(32, 24, 18, 0.04), rgba(32, 24, 18, 0.3));
  }

  .tile-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 240ms ease;
  }

  .tile-trigger:focus-visible .tile-media img {
    transform: scale(1.03);
  }

  @media (hover: hover) {
    .portfolio-gallery-tile:hover .tile-media img {
      transform: scale(1.03);
    }
  }

  .tile-duration,
  .tile-flag,
  .tile-status {
    position: absolute;
    z-index: 1;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .tile-duration {
    right: 0.85rem;
    bottom: 0.85rem;
    padding: 0.3rem 0.6rem;
    color: white;
    background: rgba(18, 14, 11, 0.72);
  }

  .tile-flag {
    left: 0.85rem;
    top: 0.85rem;
    padding: 0.3rem 0.65rem;
    color: var(--surface-ink);
    background: rgba(255, 229, 193, 0.92);
  }

  .tile-status {
    right: 0.85rem;
    top: 0.85rem;
    padding: 0.3rem 0.65rem;
    color: white;
    background: rgba(32, 24, 18, 0.78);
  }

  .tile-copy {
    display: grid;
    gap: 0.75rem;
    padding: clamp(1rem, 2.5vw, 1.25rem);
  }

  .tile-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .tile-tag {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.28rem 0.62rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid rgba(84, 60, 43, 0.08);
    color: var(--ink-soft);
    font-size: 0.78rem;
    font-weight: 700;
  }

  .tile-tag-primary {
    background: var(--surface-strong);
    color: var(--surface-ink);
  }

  .tile-headline {
    display: grid;
    gap: 0.35rem;
  }

  .tile-headline h3 {
    max-width: 16ch;
  }

  .tile-industry {
    color: var(--surface-ink);
    font-weight: 700;
    font-size: 0.92rem;
  }

  .is-feature .tile-media {
    aspect-ratio: 4 / 5;
  }

  .is-feature .tile-copy {
    gap: 0.85rem;
  }

  .is-feature h3 {
    font-size: clamp(1.3rem, 3vw, 1.8rem);
  }

  .is-compact .tile-copy {
    gap: 0.6rem;
  }

  @media (max-width: 47.99rem) {
    .tile-media,
    .is-feature .tile-media {
      aspect-ratio: 4 / 5;
    }

    .tile-copy {
      gap: 0.65rem;
      padding: 0.95rem;
    }

    .tile-headline h3 {
      max-width: none;
    }

    .tile-copy > p:last-child {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }
</style>