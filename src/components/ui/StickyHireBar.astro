---
import ButtonLink from "@components/ui/ButtonLink.astro";
import { siteConfig } from "@content/site";
---

<aside class="sticky-hire-bar" aria-label="Primary hire actions">
  <div class="sticky-hire-inner">
    <div class="sticky-copy">
      <p class="eyebrow">Hire Fast</p>
      <strong>Pick Fiverr or Upwork</strong>
    </div>
    <div class="sticky-actions">
      <ButtonLink href={siteConfig.primaryCta.href} external={true} size="sm">
        Fiverr
      </ButtonLink>
      <ButtonLink href={siteConfig.secondaryCta.href} external={true} variant="secondary" size="sm">
        Upwork
      </ButtonLink>
    </div>
  </div>
</aside>

<style>
  .sticky-hire-bar {
    position: fixed;
    inset: auto 0 0 0;
    z-index: 40;
    padding: 0.7rem 0.7rem calc(0.7rem + env(safe-area-inset-bottom));
    pointer-events: none;
  }

  .sticky-hire-inner {
    width: min(100%, 40rem);
    margin-inline: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding: 0.8rem;
    border-radius: calc(var(--radius-lg) + 0.2rem);
    background: rgba(32, 24, 18, 0.92);
    color: white;
    box-shadow: 0 22px 50px rgba(24, 16, 11, 0.28);
    pointer-events: auto;
  }

  .sticky-copy {
    display: grid;
    gap: 0.25rem;
  }

  .sticky-copy .eyebrow {
    color: rgba(255, 229, 193, 0.92);
    font-size: 0.72rem;
  }

  .sticky-copy strong {
    font-size: 0.96rem;
  }

  .sticky-actions {
    display: flex;
    gap: 0.5rem;
  }

  .sticky-actions :global(.btn-secondary) {
    background: rgba(255, 255, 255, 0.08);
    color: white;
    border-color: rgba(255, 255, 255, 0.18);
  }

  @media (min-width: 62rem) {
    .sticky-hire-bar {
      inset: auto 1rem 1rem auto;
      padding: 0;
    }

    .sticky-hire-inner {
      width: auto;
      min-width: 19rem;
    }
  }

  @media (max-width: 32rem) {
    .sticky-hire-inner {
      align-items: start;
      flex-direction: column;
      gap: 0.65rem;
      padding: 0.72rem;
    }

    .sticky-copy .eyebrow {
      display: none;
    }

    .sticky-copy strong {
      font-size: 0.92rem;
      line-height: 1.15;
    }

    .sticky-actions {
      width: 100%;
    }

    .sticky-actions :global(.btn) {
      flex: 1 1 0;
    }
  }
</style>