---
interface Props {
  eyebrow?: string;
  title: string;
  text?: string;
  align?: "start" | "center";
  compact?: boolean;
}

const { eyebrow, title, text, align = "start", compact = false } = Astro.props;
---

<div class:list={["section-header", align === "center" && "is-center", compact && "is-compact"]}>
  <div class="section-copy">
    {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
    <hgroup>
      <h2>{title}</h2>
      {text ? <p class="lead">{text}</p> : null}
    </hgroup>
  </div>
  <div class="section-actions">
    <slot name="actions" />
  </div>
</div>

<style>
  .section-header {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: var(--space-4);
  }

  .section-copy {
    display: grid;
    gap: 0.55rem;
    max-width: 40rem;
  }

  hgroup {
    display: grid;
    gap: 0.75rem;
  }

  h2 {
    margin: 0;
  }

  .section-actions {
    display: flex;
    justify-content: flex-end;
  }

  .is-center {
    text-align: center;
    flex-direction: column;
    align-items: center;
  }

  .is-center .section-actions {
    justify-content: center;
  }

  .is-compact {
    margin-bottom: var(--space-3);
  }

  @media (max-width: 44rem) {
    .section-header {
      align-items: start;
      flex-direction: column;
    }

    .section-actions {
      width: 100%;
      justify-content: start;
    }
  }
</style>