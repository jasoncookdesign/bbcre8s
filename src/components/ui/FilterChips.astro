---
export type ChipItem = {
  label: string;
  href?: string;
  active?: boolean;
};

interface Props {
  items: ChipItem[];
}

const { items } = Astro.props;
---

<div class="chip-row" role="tablist" aria-label="Portfolio filters">
  {
    items.map((item) => {
      const className = item.active ? "chip is-active" : "chip";

      if (item.href) {
        return (
          <a href={item.href} class={className} aria-current={item.active ? "page" : undefined}>
            {item.label}
          </a>
        );
      }

      return (
        <span class={className} aria-current={item.active ? "page" : undefined}>
          {item.label}
        </span>
      );
    })
  }
</div>