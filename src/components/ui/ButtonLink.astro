---
import { withBase } from "@content/site";

type Variant = "primary" | "secondary" | "ghost";
type Size = "sm" | "md";

interface Props {
  href: string;
  variant?: Variant;
  size?: Size;
  external?: boolean;
  fullWidth?: boolean;
  class?: string;
}

const {
  href,
  variant = "primary",
  size = "md",
  external = false,
  fullWidth = false,
  class: className
} = Astro.props;

const resolvedHref = external ? href : withBase(href);
---

<a
  href={resolvedHref}
  class:list={["btn", `btn-${variant}`, size === "sm" && "btn-sm", fullWidth && "btn-block", className]}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
>
  <slot />
</a>