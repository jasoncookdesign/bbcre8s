---
import { getContentStatusLabel, type ContentStatus } from "@content/types";

interface Props {
  href?: string;
  thumbnail: string;
  title: string;
  summary: string;
  eyebrow?: string;
  duration?: string;
  badge?: string;
  priority?: boolean;
  status?: ContentStatus;
}

const { href, thumbnail, title, summary, eyebrow, duration, badge, priority = false, status } = Astro.props;
const stateLabel = status && status !== "ready" ? getContentStatusLabel(status) : undefined;
const topBadge = stateLabel ?? badge;
---

<article class="video-tile card">
  {
    href ? (
      <a href={href} target="_blank" rel="noreferrer" class="video-thumb">
        <img
          src={thumbnail}
          alt={title}
          loading={priority ? "eager" : "lazy"}
          fetchpriority={priority ? "high" : "auto"}
          decoding="async"
        />
        <span class="video-play">{status === "ready" ? "Watch" : "Preview"}</span>
        {duration ? <span class="video-duration">{duration}</span> : null}
        {topBadge ? <span class="video-badge">{topBadge}</span> : null}
      </a>
    ) : (
      <div class="video-thumb" aria-label={`${title} poster preview`}>
        <img
          src={thumbnail}
          alt={title}
          loading={priority ? "eager" : "lazy"}
          fetchpriority={priority ? "high" : "auto"}
          decoding="async"
        />
        <span class="video-play">Poster Only</span>
        {duration ? <span class="video-duration">{duration}</span> : null}
        {topBadge ? <span class="video-badge">{topBadge}</span> : null}
      </div>
    )
  }
  <div class="video-copy">
    {eyebrow ? <p class="eyebrow">{eyebrow}</p> : null}
    <h3>{title}</h3>
    <p>{summary}</p>
  </div>
</article>