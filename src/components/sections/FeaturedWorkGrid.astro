---
import ButtonLink from "@components/ui/ButtonLink.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";
import SurfaceCard from "@components/ui/SurfaceCard.astro";
import VideoTile from "@components/ui/VideoTile.astro";
import { getHomepageFeaturedPortfolio, getPortfolioExternalHref, getPortfolioPoster } from "@content/portfolio";

const featured = getHomepageFeaturedPortfolio(4);
---

<section class="section section-panel">
  <div class="container">
    <SectionHeader
      eyebrow="Featured Work"
      title="Proof over promises."
      text={
        featured.length > 0
          ? "Only ready items appear here. Placeholder and draft work stay visible elsewhere without being treated like verified proof."
          : "This proof section stays reserved for approved work. It fills automatically when featured portfolio items are marked ready."
      }
    >
      <Fragment slot="actions">
        <ButtonLink href="/portfolio" variant="secondary">View Portfolio</ButtonLink>
      </Fragment>
    </SectionHeader>
  </div>
  <div class="container grid grid-2">
    {
      featured.length > 0 ? (
        featured.map((item, index) => (
          <VideoTile
            href={getPortfolioExternalHref(item)}
            thumbnail={getPortfolioPoster(item)}
            title={item.title}
            summary={item.goal ?? item.description}
            eyebrow={item.industryTag ?? item.platformTag}
            duration={item.duration}
            badge={item.useCase}
            priority={index < 2}
            status={item.status}
          />
        ))
      ) : (
        <>
          <SurfaceCard class="featured-empty-card">
            <p class="eyebrow">Ready-state guardrail</p>
            <h3>No featured clips are marked ready yet.</h3>
            <p>
              The layout still holds its place, but placeholder work is intentionally kept out of this high-trust surface.
            </p>
          </SurfaceCard>
          <SurfaceCard class="featured-empty-card" tone="strong">
            <p class="eyebrow">How it unlocks</p>
            <h3>One status change activates the section.</h3>
            <p>Keep the item public, leave it featured, and switch its status to ready when real proof is approved.</p>
          </SurfaceCard>
        </>
      )
    }
  </div>
</section>

<style>
  .featured-empty-card {
    padding: clamp(1rem, 2.8vw, 1.25rem);
    display: grid;
    gap: 0.6rem;
  }
</style>
