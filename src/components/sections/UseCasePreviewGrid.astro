---
import ButtonLink from "@components/ui/ButtonLink.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";
import SurfaceCard from "@components/ui/SurfaceCard.astro";
import {
  getPortfolioExternalHref,
  getPortfolioPoster,
  getPortfolioStatusText,
  getUseCasePreviewItems
} from "@content/portfolio";

const previewItems = getUseCasePreviewItems();
---

<section class="section section-panel">
  <div class="container">
    <SectionHeader
      eyebrow="Portfolio Preview"
      title="Browse by use case, not just by category."
      text="These cards can show placeholder or draft media for layout validation, while ready proof is still reserved for higher-trust surfaces."
    >
      <Fragment slot="actions">
        <ButtonLink href="/portfolio" variant="secondary">View Portfolio</ButtonLink>
      </Fragment>
    </SectionHeader>
    <div class="grid grid-2 use-case-grid">
      {
        previewItems.map((preview) => {
          const href = getPortfolioExternalHref(preview.item);
          const statusText = getPortfolioStatusText(preview.item);

          return (
            <SurfaceCard class="use-case-card">
              {
                href ? (
                  <a href={href} target="_blank" rel="noreferrer" class="thumb-wrap">
                    <img src={getPortfolioPoster(preview.item)} alt={preview.item.title} loading="lazy" />
                    <span class="duration">{preview.item.duration ?? "Preview"}</span>
                    {preview.item.status !== "ready" ? <span class="status-chip">{statusText}</span> : null}
                  </a>
                ) : (
                  <div class="thumb-wrap" aria-label={`${preview.item.title} poster preview`}>
                    <img src={getPortfolioPoster(preview.item)} alt={preview.item.title} loading="lazy" />
                    <span class="duration">{preview.item.duration ?? "Preview"}</span>
                    <span class="status-chip">{statusText}</span>
                  </div>
                )
              }
              <div class="copy">
                <p class="eyebrow">{preview.label}</p>
                <h3>{preview.item.title}</h3>
                <p>{preview.summary}</p>
                <div class="row-actions">
                  <ButtonLink href="/portfolio" variant="secondary" size="sm">View Portfolio</ButtonLink>
                  {
                    href ? (
                      <a href={href} target="_blank" rel="noreferrer" class="text-link">
                        {preview.item.status === "ready" ? "Watch Clip" : "Open Preview"}
                      </a>
                    ) : (
                      <span class="text-link is-muted">Poster only</span>
                    )
                  }
                </div>
              </div>
            </SurfaceCard>
          );
        })
      }
    </div>
  </div>
</section>

<style>
  .use-case-grid {
    gap: 1rem;
  }

  .use-case-card {
    overflow: hidden;
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(0, 1.15fr);
  }

  .thumb-wrap {
    position: relative;
    display: block;
    min-height: 100%;
    background: rgba(32, 24, 18, 0.08);
  }

  .thumb-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .duration,
  .status-chip {
    position: absolute;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .duration {
    left: 0.75rem;
    bottom: 0.75rem;
    padding: 0.3rem 0.55rem;
    background: rgba(18, 14, 11, 0.72);
    color: white;
  }

  .status-chip {
    top: 0.75rem;
    right: 0.75rem;
    padding: 0.3rem 0.6rem;
    background: rgba(32, 24, 18, 0.82);
    color: white;
  }

  .copy {
    padding: clamp(1rem, 2.6vw, 1.25rem);
    display: grid;
    gap: 0.7rem;
    align-content: center;
  }

  .row-actions {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .text-link {
    text-decoration: none;
    font-weight: 700;
    color: var(--surface-ink);
  }

  .text-link.is-muted {
    color: var(--ink-soft);
  }

  @media (max-width: 43rem) {
    .use-case-card {
      grid-template-columns: 1fr;
    }

    .thumb-wrap {
      aspect-ratio: 9 / 10;
    }
  }
</style>