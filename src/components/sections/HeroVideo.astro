---
import CTARow from "@components/ui/CTARow.astro";
import SurfaceCard from "@components/ui/SurfaceCard.astro";
import { heroVideo } from "@content/home";
import {
  getHeroPreviewPortfolio,
  getPortfolioExternalHref,
  getPortfolioPoster,
  getPortfolioStatusText
} from "@content/portfolio";
import { siteConfig } from "@content/site";

const reelItems = getHeroPreviewPortfolio(4);
const hasReadyHeroVideo = heroVideo.status === "ready" && Boolean(heroVideo.videoSrc);
const heroPoster = heroVideo.poster ?? (reelItems[0] ? getPortfolioPoster(reelItems[0]) : undefined);
---

<section class="section">
  <div class="container grid grid-2 hero-wrap">
    <div class="copy">
      <p class="eyebrow">Video-First UGC Portfolio</p>
      <h1>UGC that stops the scroll and moves buyers closer to yes.</h1>
      <p class="lead">
        Fast, polished creator content for Shopify brands, Amazon sellers, SaaS startups, and local
        businesses that need social-native product selling.
      </p>
      <div class="stats-inline">
        <span class="stat-pill">Vertical-first delivery</span>
        <span class="stat-pill">Hooks built for retention</span>
        <span class="stat-pill">Platform-native edits</span>
      </div>
      <CTARow
        items={[
          { label: siteConfig.primaryCta.label, href: siteConfig.primaryCta.href, external: true },
          { label: "View Portfolio", href: "/portfolio", variant: "secondary" },
          { label: siteConfig.secondaryCta.label, href: siteConfig.secondaryCta.href, external: true, variant: "ghost" }
        ]}
      />
    </div>
    <SurfaceCard class="frame" tone="strong">
      <div class="reel-meta">
        <div>
          <p class="eyebrow">{heroVideo.eyebrow}</p>
          <p class="kicker">
            {
              hasReadyHeroVideo
                ? "A real highlight reel is configured and ready to play here."
                : "This slot currently uses a simulated reel so the layout stays validated until a real hero video is ready."
            }
          </p>
        </div>
        <span class="reel-chip">{hasReadyHeroVideo ? "Ready video" : "Preview mode"}</span>
      </div>

      {
        hasReadyHeroVideo ? (
          <div class="hero-video-shell">
            <video class="hero-video" controls playsinline preload="metadata" poster={heroPoster}>
              <source src={heroVideo.videoSrc} />
            </video>
          </div>
        ) : (
          <>
            <div class="reel-stage" aria-label="Simulated highlight reel preview">
              {
                reelItems.length > 0 ? (
                  reelItems.map((item, index) => {
                    const href = getPortfolioExternalHref(item);
                    const statusText = getPortfolioStatusText(item);

                    const slideContent = (
                      <>
                        <img
                          src={getPortfolioPoster(item)}
                          alt={item.title}
                          loading={index === 0 ? "eager" : "lazy"}
                          fetchpriority={index === 0 ? "high" : "auto"}
                          decoding="async"
                        />
                        <div class="slide-overlay">
                          <div class="slide-topline">
                            <span class="slide-tag">{item.useCase}</span>
                            <div class="slide-meta">
                              {item.duration ? <span class="slide-duration">{item.duration}</span> : null}
                              {item.status !== "ready" ? <span class="slide-state">{statusText}</span> : null}
                            </div>
                          </div>
                          <div class="slide-copy">
                            <p class="eyebrow">{item.industryTag ?? item.platformTag}</p>
                            <h2>{item.title}</h2>
                            <p>{item.goal ?? item.description}</p>
                          </div>
                        </div>
                      </>
                    );

                    return href ? (
                      <a
                        href={href}
                        target="_blank"
                        rel="noreferrer"
                        class="reel-slide"
                        style={`--slide-index:${index};`}
                      >
                        {slideContent}
                      </a>
                    ) : (
                      <div class="reel-slide" style={`--slide-index:${index};`}>
                        {slideContent}
                      </div>
                    );
                  })
                ) : (
                  <div class="reel-empty">
                    {heroPoster ? <img src={heroPoster} alt={heroVideo.title} loading="eager" decoding="async" /> : null}
                    <div class="slide-overlay">
                      <div class="slide-copy">
                        <p class="eyebrow">Preview mode</p>
                        <h2>{heroVideo.title}</h2>
                        <p>{heroVideo.detail}</p>
                      </div>
                    </div>
                  </div>
                )
              }
            </div>
            {reelItems.length > 0 ? (
              <div class="reel-progress" aria-hidden="true">
                {reelItems.map((_, index) => <span style={`--slide-index:${index};`}></span>)}
              </div>
            ) : null}
            <p class="reel-note">{heroVideo.detail}</p>
          </>
        )
      }
    </SurfaceCard>
  </div>
</section>

<style>
  .hero-wrap {
    align-items: center;
    gap: clamp(1.25rem, 3vw, 2.5rem);
  }

  .copy {
    display: grid;
    gap: var(--space-4);
  }

  .frame {
    overflow: hidden;
    min-height: 22rem;
    padding: 0.85rem;
    display: grid;
    gap: 0.8rem;
  }

  .reel-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding: 0.35rem 0.2rem 0;
  }

  .reel-chip {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.68);
    border: 1px solid rgba(84, 60, 43, 0.08);
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--surface-ink);
  }

  .hero-video-shell,
  .reel-stage {
    position: relative;
    min-height: 25rem;
    overflow: hidden;
    border-radius: calc(var(--radius-lg) - 0.35rem);
    background:
      linear-gradient(180deg, rgba(32, 24, 18, 0.08), rgba(32, 24, 18, 0.24)),
      rgba(255, 255, 255, 0.4);
  }

  .hero-video {
    width: 100%;
    height: 100%;
    min-height: 25rem;
    display: block;
    object-fit: cover;
    background: rgba(18, 14, 11, 0.82);
  }

  .reel-slide,
  .reel-empty {
    position: absolute;
    inset: 0;
    display: block;
  }

  .reel-slide {
    opacity: 0;
    transform: scale(1.02);
    animation: reel-cycle 24s infinite;
    animation-delay: calc(var(--slide-index) * 6s);
    will-change: opacity, transform;
  }

  .reel-slide img,
  .reel-empty img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .slide-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1rem;
    background: linear-gradient(180deg, rgba(20, 15, 11, 0.14), rgba(20, 15, 11, 0.7));
    color: white;
  }

  .slide-topline {
    display: flex;
    align-items: start;
    justify-content: space-between;
    gap: 0.75rem;
  }

  .slide-meta {
    display: flex;
    flex-wrap: wrap;
    justify-content: end;
    gap: 0.45rem;
  }

  .slide-tag,
  .slide-duration,
  .slide-state {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    font-size: 0.82rem;
    font-weight: 700;
  }

  .slide-tag {
    background: rgba(255, 229, 193, 0.9);
    color: var(--surface-ink);
  }

  .slide-duration {
    background: rgba(255, 255, 255, 0.14);
    color: white;
  }

  .slide-state {
    background: rgba(32, 24, 18, 0.78);
    color: white;
  }

  .slide-copy {
    display: grid;
    gap: 0.55rem;
    max-width: 17rem;
  }

  .slide-copy .eyebrow {
    color: rgba(255, 229, 193, 0.92);
  }

  .slide-copy h2 {
    font-size: clamp(1.45rem, 5vw, 2.15rem);
    line-height: 1.02;
  }

  .slide-copy p:last-child {
    color: rgba(255, 247, 240, 0.9);
  }

  .reel-note {
    color: var(--ink-soft);
    font-size: 0.92rem;
  }

  .reel-progress {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .reel-progress span {
    position: relative;
    height: 0.3rem;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(84, 60, 43, 0.12);
  }

  .reel-progress span::after {
    content: "";
    position: absolute;
    inset: 0;
    transform: scaleX(0);
    transform-origin: left;
    background: linear-gradient(135deg, var(--accent) 0%, #ff8444 100%);
    animation: reel-progress 24s infinite;
    animation-delay: calc(var(--slide-index) * 6s);
  }

  @keyframes reel-cycle {
    0% {
      opacity: 0;
      transform: scale(1.02);
    }

    4% {
      opacity: 1;
      transform: scale(1);
    }

    22% {
      opacity: 1;
      transform: scale(1);
    }

    26% {
      opacity: 0;
      transform: scale(1.03);
    }

    100% {
      opacity: 0;
      transform: scale(1.03);
    }
  }

  @keyframes reel-progress {
    0% {
      transform: scaleX(0);
    }

    22% {
      transform: scaleX(1);
    }

    100% {
      transform: scaleX(1);
    }
  }

  @media (max-width: 47.99rem) {
    .copy {
      gap: var(--space-3);
    }

    .reel-meta {
      align-items: start;
      flex-direction: column;
    }

    .hero-video-shell,
    .reel-stage,
    .hero-video {
      min-height: 19.5rem;
    }

    .slide-overlay {
      padding: 0.85rem;
    }

    .slide-copy {
      max-width: none;
    }

    .slide-copy p:last-child {
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .reel-slide,
    .reel-progress span::after {
      animation: none;
    }

    .reel-slide {
      opacity: 0;
      transform: none;
    }

    .reel-slide:first-child {
      opacity: 1;
    }

    .reel-progress span::after {
      transform: scaleX(1);
      opacity: 0.4;
    }
  }
</style>
