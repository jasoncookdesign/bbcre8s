---
/*
  §8 Contact — dusty rose. Reads the contact email from src/content/site.ts.
  Session 2 (2026-06-14): Web3Forms + cal.com live embed wired.
  - Form posts to Web3Forms; on success redirects to /thank-you.
  - cal.com iframe embed with brandColor=#D9A5B3 (Dusty Rose accent).
  - Submit handler in TreatmentBLayout validates first; allows native submit on pass.
*/
import { intakeFallback } from "@content/site";

const email = intakeFallback.email ?? "info@bbcre8s.com";
---

<section class="contact-section" id="contact" aria-label="Contact">
  <div class="container">
    <div class="contact-inner">
      <h2 class="contact-heading">Let's Work Together</h2>
      <p class="contact-body">
        Tell me about your project — event, campaign, product launch, or retainer.
        I'll follow up within one business day.
      </p>

      <!-- Web3Forms — posts on valid submit; redirects to /thank-you on success. -->
      <form
        class="contact-form"
        id="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        novalidate
      >
        <input type="hidden" name="access_key" value="b79f9506-16bd-44c8-9c7f-f48715d62f26" />
        <input type="hidden" name="redirect" value="https://bbcre8s.com/thank-you" />
        <input type="hidden" name="subject" value="New inquiry — bbcre8s.com" />
        <input type="hidden" name="from_name" value="bbcre8s.com Contact Form" />
        <div class="form-row">
          <div class="form-field">
            <input type="text" name="name" placeholder="Your Name" class="form-input" autocomplete="name" aria-describedby="err-name" required />
            <span class="form-error" id="err-name" role="alert">Please enter your name.</span>
          </div>
          <div class="form-field">
            <input type="email" name="email" placeholder="Email Address" class="form-input" autocomplete="email" aria-describedby="err-email" required />
            <span class="form-error" id="err-email" role="alert">Enter a valid email so Bella can reply.</span>
          </div>
        </div>
        <div class="form-field">
          <input type="text" name="company" placeholder="Brand / Company (optional)" class="form-input" autocomplete="organization" />
        </div>
        <div class="form-field">
          <textarea name="message" placeholder="What are you working on?" class="form-input" rows="4" aria-describedby="err-message" required></textarea>
          <span class="form-error" id="err-message" role="alert">Tell me a little about your project.</span>
        </div>
        <button type="submit" class="btn btn-primary-inv" style="align-self: flex-end; padding: 1rem 2.25rem; font-size: 0.9rem;">
          Send Message
        </button>
      </form>

      <div class="contact-divider">Or reach me directly</div>
      <div class="contact-channels">
        <a class="contact-channel" href={`mailto:${email}`}>
          <span class="contact-channel-label">Email</span>
          <span class="contact-channel-value">{email}</span>
        </a>
        <button type="button" class="contact-channel" id="book-toggle" aria-expanded="false" aria-controls="book">
          <span class="contact-channel-label">Book a Call <span id="book-arrow" aria-hidden="true">↓</span></span>
          <span class="contact-channel-value">Pick a time</span>
        </button>
      </div>

      <!-- Booking — cal.com live iframe embed. brandColor=D9A5B3 (Dusty Rose). -->
      <div class="book-collapse" id="book" data-open="false">
        <div class="book-collapse-inner">
          <div class="book-module">
            <div class="book-head">
              <span class="book-head-title">Book a Call</span>
              <span class="book-head-powered">Powered by cal.com</span>
            </div>
            <div class="book-body">
              <iframe
                src="https://cal.com/bbcre8s/30min?embed=true&theme=light&brandColor=D9A5B3&hideEventTypeDetails=false&layout=month_view"
                width="100%"
                height="600"
                frameborder="0"
                title="Book a 30-minute call with Bella B"
                loading="lazy"
                style="display:block;border:none;min-height:600px;"
              ></iframe>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
