---
import ButtonLink from "@components/ui/ButtonLink.astro";
import { primaryNav, utilityNav } from "@content/navigation";
import { siteConfig, withBase } from "@content/site";

interface Props {
  pathname: string;
}

const { pathname } = Astro.props;
---

<header class="site-header">
  <div class="container bar">
    <div class="brand-lockup">
      <a href={withBase("/")} class="logo">bbcre8s</a>
      <p class="tagline">Video-first UGC for product-led brands</p>
    </div>
    <nav aria-label="Main navigation" class="nav-shell">
      <ul class="primary-list">
        {
          primaryNav.map((item) => {
            const isActive = pathname === item.href;
            return (
              <li>
                <a href={item.href} class:list={{ active: isActive, cta: item.isPrimary }}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
      <ul class="utility-list">
        {
          utilityNav.map((item) => {
            const isActive = pathname === item.href;
            return (
              <li>
                <a href={item.href} class:list={{ active: isActive, utility: true }}>
                  {item.label}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
    <div class="header-actions">
      <ButtonLink href="/portfolio" variant="ghost" size="sm">View Portfolio</ButtonLink>
      <ButtonLink href={siteConfig.primaryCta.href} external={true} size="sm">
        {siteConfig.primaryCta.label}
      </ButtonLink>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 30;
    -webkit-backdrop-filter: blur(12px);
    backdrop-filter: blur(12px);
    background: color-mix(in srgb, rgba(247, 243, 235, 0.82) 88%, white);
    border-bottom: 1px solid rgba(84, 60, 43, 0.08);
  }

  .bar {
    min-height: var(--header-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding-block: 0.7rem;
  }

  .brand-lockup {
    display: grid;
    gap: 0.15rem;
    flex: 0 0 auto;
  }

  .logo {
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.02rem;
    letter-spacing: 0.01em;
  }

  .tagline {
    margin: 0;
    font-size: 0.74rem;
    color: var(--ink-faint);
  }

  .nav-shell {
    display: flex;
    align-items: center;
    justify-content: center;
    flex: 1 1 auto;
    gap: var(--space-2);
    min-width: 0;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.35rem;
    align-items: center;
    overflow-x: auto;
    scrollbar-width: none;
  }

  ul::-webkit-scrollbar {
    display: none;
  }

  .primary-list {
    padding: 0.35rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.48);
    border: 1px solid rgba(84, 60, 43, 0.08);
  }

  .utility-list {
    display: none;
  }

  li {
    flex: 0 0 auto;
  }

  a {
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.5rem 0.78rem;
    border-radius: 999px;
    border: 1px solid transparent;
    display: inline-flex;
    white-space: nowrap;
    color: var(--ink-soft);
    transition:
      background-color var(--transition-base),
      border-color var(--transition-base),
      color var(--transition-base);
  }

  a.active {
    background: var(--surface-strong);
    border-color: rgba(242, 102, 47, 0.2);
    color: var(--surface-ink);
  }

  a.cta {
    border-color: rgba(242, 102, 47, 0.24);
  }

  .header-actions {
    display: none;
    align-items: center;
    gap: var(--space-2);
    flex: 0 0 auto;
  }

  @media (min-width: 50rem) {
    a {
      font-size: 0.95rem;
      padding: 0.5rem 0.9rem;
    }

    .utility-list {
      display: flex;
    }

    .header-actions {
      display: flex;
    }
  }

  @media (max-width: 55rem) {
    .bar {
      align-items: start;
      flex-direction: column;
    }

    .nav-shell {
      width: 100%;
      justify-content: start;
      overflow-x: auto;
    }
  }

  @media (max-width: 34rem) {
    .tagline {
      display: none;
    }
  }
</style>
