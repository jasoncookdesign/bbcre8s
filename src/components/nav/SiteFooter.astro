---
import ButtonLink from "@components/ui/ButtonLink.astro";
import { primaryNav, utilityNav } from "@content/navigation";
import { siteConfig } from "@content/site";
---

<footer class="site-footer">
  <div class="container footer-grid card card-strong">
    <div class="stack-sm intro">
      <p class="eyebrow">Built for Conversion</p>
      <p class="brand">bbcre8s UGC Portfolio</p>
      <p>Premium, energetic UGC presentation with portfolio proof always one tap away.</p>
    </div>
    <div class="footer-nav">
      <div class="footer-links">
        {primaryNav.map((item) => <a href={item.href}>{item.label}</a>)}
        {utilityNav.map((item) => <a href={item.href}>{item.label}</a>)}
      </div>
      <div class="links">
        {
          siteConfig.offsitePlatforms.map((platform) => (
            <ButtonLink href={platform.href} external={true} variant="secondary" size="sm">
              {platform.ctaLabel}
            </ButtonLink>
          ))
        }
      </div>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    padding: 0 0 calc(var(--cta-bar-height) + env(safe-area-inset-bottom) + var(--space-4));
  }

  .footer-grid {
    display: flex;
    align-items: start;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding: clamp(1.25rem, 3vw, 2rem);
  }

  .brand {
    color: var(--ink);
    font-weight: 700;
    font-size: 1.1rem;
  }

  .intro {
    max-width: 24rem;
  }

  .footer-nav {
    display: grid;
    gap: var(--space-3);
    justify-items: end;
  }

  .footer-links,
  .links {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .footer-links a {
    text-decoration: none;
    font-weight: 600;
    color: var(--ink-soft);
  }

  @media (max-width: 44rem) {
    .footer-nav {
      justify-items: start;
    }

    .footer-links,
    .links {
      justify-content: flex-start;
    }
  }
</style>
