---
import BaseLayout from "@layouts/BaseLayout.astro";
import CTARow from "@components/ui/CTARow.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";
import SurfaceCard from "@components/ui/SurfaceCard.astro";
import { siteConfig } from "@content/site";
import { getVisibleServicePackages, processSteps } from "@content/services";

const servicePackages = getVisibleServicePackages();
---

<BaseLayout
  title="Services | bbcre8s UGC"
  description="Clear UGC package options including single videos, bundles, ad creative packs, and product explainer content."
  pathname={Astro.url.pathname}
>
  <section class="section">
    <div class="container stack-lg">
      <div class="stack-md">
        <p class="eyebrow">Services</p>
        <h1>Clear UGC offers built for fast decisions.</h1>
        <p class="lead">
          Pick the package shape that fits the job: one video, a bundle, an ad pack, or a product explainer.
        </p>
      </div>

      <div class="stats-inline">
        <span class="stat-pill">Short-form focused</span>
        <span class="stat-pill">No pricing maze</span>
        <span class="stat-pill">Built for platform booking</span>
      </div>

      <CTARow
        items={[
          { label: siteConfig.primaryCta.label, href: siteConfig.primaryCta.href, external: true },
          { label: siteConfig.secondaryCta.label, href: siteConfig.secondaryCta.href, external: true, variant: "secondary" },
          { label: "View Portfolio", href: "/portfolio", variant: "ghost" }
        ]}
      />

      <div class="grid grid-2 packages">
        {
          servicePackages.map((pkg) => (
            <SurfaceCard class="package" tone={pkg.callout ? "strong" : "default"}>
              <div class="package-topline">
                <p class="eyebrow">{pkg.tier}</p>
                {pkg.callout ? <span class="package-callout">{pkg.callout}</span> : null}
              </div>
              <h2>{pkg.headline}</h2>
              <p>{pkg.bestFor}</p>
              <p class="turnaround">Turnaround: {pkg.turnaround}</p>
              <ul>
                {pkg.deliverables.map((d) => <li>{d.name}</li>)}
              </ul>
            </SurfaceCard>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-panel">
    <div class="container">
      <SectionHeader
        eyebrow="Simple Process"
        title="Easy to brief, easy to book."
        text="The service flow is intentionally light: clear scope, strong creative direction, and delivery built for launch speed."
      />
      <div class="grid grid-3 process-grid">
        {
          processSteps.map((step, index) => (
            <SurfaceCard class="process-card">
              <p class="eyebrow">Step {index + 1}</p>
              <h3>{step.title}</h3>
              <p>{step.detail}</p>
            </SurfaceCard>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <SurfaceCard class="final-push" tone="strong">
        <div class="stack-sm">
          <p class="eyebrow">Ready to Book</p>
          <h2>Choose a platform and send the brief.</h2>
          <p>
            The fastest path is still Fiverr or Upwork. Share the product, the goal, and the timeline, and I can point you to the best-fit package quickly.
          </p>
        </div>
        <CTARow
          items={[
            { label: siteConfig.primaryCta.label, href: siteConfig.primaryCta.href, external: true },
            { label: siteConfig.secondaryCta.label, href: siteConfig.secondaryCta.href, external: true, variant: "secondary" }
          ]}
        />
      </SurfaceCard>
    </div>
  </section>
</BaseLayout>

<style>
  .packages,
  .process-grid {
    margin-top: 0;
  }

  .package,
  .process-card,
  .final-push {
    padding: clamp(1rem, 2.8vw, 1.3rem);
    display: grid;
    gap: 0.75rem;
  }

  .package-topline {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .package-callout {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.25rem 0.6rem;
    border-radius: 999px;
    background: var(--surface-strong);
    color: var(--surface-ink);
    font-size: 0.78rem;
    font-weight: 700;
  }

  h2 {
    font-size: 1.35rem;
  }

  ul {
    margin: 0;
    padding-left: 1.1rem;
    color: var(--ink-soft);
    display: grid;
    gap: 0.35rem;
  }

  .turnaround {
    color: var(--ink);
    font-weight: 700;
  }
</style>
