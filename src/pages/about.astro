---
import BaseLayout from "@layouts/BaseLayout.astro";
import CTARow from "@components/ui/CTARow.astro";
import SectionHeader from "@components/ui/SectionHeader.astro";
import SurfaceCard from "@components/ui/SurfaceCard.astro";
import { aboutContent } from "@content/about";
import { siteConfig, withBase } from "@content/site";
---

<BaseLayout
  title="About | bbcre8s UGC"
  description="Learn the commercial strengths behind this creator portfolio: on-camera presence, product understanding, and polished delivery."
  pathname={Astro.url.pathname}
>
  <section class="section">
    <div class="container grid grid-2 hero-grid">
      <div class="stack-lg">
        <p class="eyebrow">About</p>
        <h1>On-camera confidence, product fluency, and clean execution.</h1>
        <p class="lead">{aboutContent.intro}</p>
        <p>{aboutContent.positioning}</p>
        <CTARow
          items={[
            { label: siteConfig.primaryCta.label, href: siteConfig.primaryCta.href, external: true },
            { label: "View Portfolio", href: "/portfolio", variant: "secondary" }
          ]}
        />
      </div>
      <SurfaceCard class="profile" tone="strong">
        <img src={withBase("/media/headshots/about-headshot.svg")} alt="Creator headshot" loading="lazy" />
        <div class="proof-pills">
          {aboutContent.proofNotes.map((item) => <span class="stat-pill">{item}</span>)}
        </div>
      </SurfaceCard>
    </div>
  </section>

  <section class="section section-tight">
    <div class="container">
      <SectionHeader
        eyebrow="Strengths"
        title="What brands are actually hiring for."
        text="This page stays commercially relevant by focusing on execution strengths, not personal backstory."
      />
      <div class="grid grid-2 strengths-grid">
        {
          aboutContent.strengths.map((item) => (
            <SurfaceCard class="strength-card">
              <p class="eyebrow">Strength</p>
              <h3>{item.title}</h3>
              <p>{item.detail}</p>
            </SurfaceCard>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section section-panel">
    <div class="container grid grid-2">
      <SurfaceCard class="block">
        <SectionHeader title="Who I work with" compact={true} />
        <ul>
          {aboutContent.audience.map((item) => <li>{item}</li>)}
        </ul>
      </SurfaceCard>
      <SurfaceCard class="block" tone="strong">
        <SectionHeader title="How I approach the work" compact={true} />
        <ul>
          {aboutContent.principles.map((item) => <li>{item}</li>)}
        </ul>
      </SurfaceCard>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-grid {
    align-items: start;
  }

  .profile {
    min-height: 20rem;
    overflow: hidden;
    padding: 0.75rem;
    display: grid;
    gap: 0.85rem;
  }

  .profile img {
    width: 100%;
    height: 100%;
    min-height: 20rem;
    object-fit: cover;
    border-radius: calc(var(--radius-lg) - 0.35rem);
  }

  .proof-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .strengths-grid {
    gap: 1rem;
  }

  .strength-card,
  .block {
    padding: clamp(1rem, 2.8vw, 1.3rem);
    display: grid;
    gap: 0.6rem;
  }

  ul {
    margin: 0.2rem 0 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.45rem;
    color: var(--ink-soft);
  }
</style>
